# ─── Simulator Environment Variables ─────────────────────────────────────────
# Copy file này thành .env và điền giá trị phù hợp với môi trường

# MQTT broker URL
# Local:  mqtt://localhost:1883  (nếu dùng broker riêng)
# Public: mqtt://broker.hivemq.com:1883  (mặc định, dùng cho dev/demo)
MQTT_URL=mqtt://broker.hivemq.com:1883

# MQTT topic — phải trùng với backend subscriber
MQTT_TOPIC=rtls/location/ikyrts_dashboard

# Backend API URL — để simulator sync danh sách nhân viên
# Local: http://localhost:3003
# VPS:   http://<VPS_IP>:3003  hoặc  https://yourdomain.com
API_URL=http://localhost:3003
